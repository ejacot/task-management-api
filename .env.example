DB_URL=jdbc:postgresql://postgres:5432/task_management
DB_USERNAME=task_user
DB_PASSWORD=change-me
SPRING_PROFILES_ACTIVE=default
ROOMLY_TOKEN_SECRET=change-this-to-a-long-random-production-secret

ROOMLY_MAIL_ENABLED=true
ROOMLY_SMTP_HOST=smtp.gmail.com
ROOMLY_SMTP_PORT=587
ROOMLY_SMTP_USERNAME=your-gmail-address@gmail.com
ROOMLY_SMTP_PASSWORD=your-gmail-app-password
ROOMLY_SMTP_CONNECTION_TIMEOUT=5000
ROOMLY_SMTP_TIMEOUT=5000
ROOMLY_SMTP_WRITE_TIMEOUT=5000
ROOMLY_MAIL_FROM=your-gmail-address@gmail.com
ROOMLY_MAIL_FROM_NAME=Roomly Work

# Optional provider keys for the outbound_messages queue.
# Until these are configured, Roomly stores EMAIL/SMS/PUSH messages in DB for a worker/provider integration.
ROOMLY_SMS_PROVIDER=
ROOMLY_VAPID_PUBLIC_KEY=
ROOMLY_VAPID_PRIVATE_KEY=
